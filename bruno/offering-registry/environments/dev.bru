vars {
  baseUri: http://localhost:9005
  offeringId: xpt-test-melanie-001
  titleId: t-xpt-test-melanie-001
  partnerId: REPLACE_WITH_YOUR_SELLER_ID
  productId: REPLACE_WITH_PARTNER_CENTER_PRODUCT_ID
  dnaGroupId1: 00000000-0000-0000-0000-000000000001
}
vars:secret [
  bearerToken
]

# Local-run env.
# baseUri assumes you're running services.partnerregistry locally with
# ASPNETCORE_ENVIRONMENT=Development. In that mode the S2S auth policy is
# bypassed (Startup.cs:386: policy.RequireAssertion(context => true)),
# so `bearerToken` is unused but kept for parity with other envs.
#
# Source for port 9005: appsettings.en-development.json:9 (HostingSettings.ServicePort)
